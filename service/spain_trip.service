[Unit]
Description=Flask Service for 2026 Spain Family Trip Guide
After=network.target

[Service]
# 서버의 사용자 계정 이름을 적으세요 (예: ubuntu 또는 pi 등)
User=ubuntu
# app.py 파일이 있는 절대 경로를 적으세요
WorkingDirectory=/share/spain
# 가상환경(venv)을 쓰신다면 venv 안의 python 경로를, 아니면 시스템 python3 경로를 적으세요
ExecStart=/usr/bin/python3 app.py
Restart=always

[Install]
WantedBy=multi-user.target

